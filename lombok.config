config.stopBubbling = true

# 子类 equals/hashCode/toString 调用父类，保证 AbstractUniverModel.extras 参与比较
# Subclass equals/hashCode/toString call super, so AbstractUniverModel.extras is included.
lombok.toString.callSuper = CALL
lombok.equalsAndHashCode.callSuper = CALL

# 给生成代码打 @lombok.Generated，JaCoCo 自动忽略，覆盖率更贴近"手写代码"
# Add @lombok.Generated to generated methods so JaCoCo ignores them.
lombok.addLombokGeneratedAnnotation = true
